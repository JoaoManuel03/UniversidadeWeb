<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Novo Professor</title>
<link rel="stylesheet" href="../css/style.css">
</head>
<body>

<div class="main">

    <div class="content">

        <div class="card">

            <h2>Novo Professor</h2>

            <form>

                <div class="form-group">
                    <label>Matricula</label>
                    <input type="number">
                </div>

                <div class="form-group">
                    <label>Nome</label>
                    <input type="text">
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <input type="email">
                </div>

                <div class="form-group">
                    <label>Telefone</label>
                    <input type="text">
                </div>

                <button class="btn">
                    Salvar
                </button>

            </form>

        </div>

    </div>

</div>

</body>
</html>